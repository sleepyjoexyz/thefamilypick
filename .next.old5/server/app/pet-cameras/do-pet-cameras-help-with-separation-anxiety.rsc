":"GPS Trackers"}]}],["$","li",null,{"children":["$","$L5",null,{"href":"/grooming-tools","className":"text-gray-400 hover:text-white transition","children":"Grooming Tools"}]}]]}]]}]]}],["$","div",null,{"className":"border-t border-gray-800 pt-8 mb-8","children":[["$","h3",null,{"className":"text-white font-semibold mb-4","children":"Our Sites"}],["$","div",null,{"className":"flex flex-wrap gap-4 text-sm","children":[["$","$L5",null,{"href":"https://thekitchenpick.com","className":"text-gray-400 hover:text-white transition","children":"The Kitchen Pick"}],["$","$L5",null,{"href":"https://thegadgetpick.com","className":"text-gray-400 hover:text-white transition","children":"The Gadget Pick"}]]}]]}],"$L6","$L7"]}]}]]}]}]]}],{"children":["$L8",{"children":["$L9",{"children":["$La",{},null,false,false]},null,false,false]},null,false,false]},null,false,false],"$Lb",false]],"m":"$undefined","G":["$c",[]],"S":true}
