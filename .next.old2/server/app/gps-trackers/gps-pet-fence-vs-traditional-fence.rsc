HOA**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"None needed"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"Often required"}]]}],["$","tr","6",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Containment reliability**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"~85-90%"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"99%+"}]]}],["$","tr","7",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Training required**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"Yes (2-4 weeks)"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"No (instinctive)"}]]}],["$","tr","8",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Portability**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"Fully portable"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"Permanent"}]]}],["$","tr","9",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Works for all dogs**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"No (requires training)"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"Yes"}]]}],["$","tr","10",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Real-time tracking**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2 ","children":"Yes"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2 ","children":"No"}]]}],["$","tr","11",{"className":"","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2 ","children":"**Prevents outsider access**"}],["$","td","1",{"className":"border border-