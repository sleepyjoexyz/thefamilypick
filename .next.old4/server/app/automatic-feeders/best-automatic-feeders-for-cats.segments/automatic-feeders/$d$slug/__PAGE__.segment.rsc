0:{"buildId":"hCurFP6vqgVtfXUmC_lIR","rsc":["$","$1","c",{"children":[["$","article",null,{"className":"bg-white","children":[["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-6","children":["$","nav",null,{"className":"flex items-center space-x-2 text-sm text-gray-600","children":[["$","$L2",null,{"href":"/","className":"hover:text-blue-600","children":"Home"}],[["$","div","/automatic-feeders",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","$L2",null,{"href":"/automatic-feeders","className":"hover:text-blue-600","children":"Automatic Feeders"}]]}],["$","div","/automatic-feeders/best-automatic-feeders-for-cats",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","span",null,{"className":"text-gray-900 font-medium","children":"Best Automatic Pet Feeders for Cats: Portion Control and Weight Management Guide"}]]}]]]}]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-b border-gray-200","children":[["$","h1",null,{"className":"text-4xl font-bold text-gray-900 mb-4","children":"Best Automatic Pet Feeders for Cats: Portion Control and Weight Management Guide"}],["$","p",null,{"className":"text-lg text-gray-600","children":"Discover the best automatic feeders specifically designed for cats. Learn about portion control for weight management, how to prevent overeating, and which features matter most for feline health."}]]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700","children":[["$","h2","0",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-gray-700 leading-relaxed my-4","children":"Cats are notorious for demanding food at all hours, leading many owners to leave out bowls of dry food. Free-feeding often results in obesity, diabetes, and metabolic problems. Automatic cat feeders put portion control back into your paws, dispensing measured amounts at scheduled times. This guide covers the best automatic feeders specifically designed for cats, focusing on portion control, feeding frequency, and health benefits."}],["$","h2","2",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Why Automatic Feeders Are Important for Cats"}],["$","p","3",{"className":"text-gray-700 leading-relaxed my-4","children":"Cats have evolved to hunt multiple small meals throughout the day—naturally grazing in short feeding bursts rather than eating one large meal. In captivity, free-fed cats often overeat because:"}],["$","ul","4",{"className":"list-disc list-inside space-y-2 my-4","children":[["$","li","0",{"className":"text-gray-700","children":"Boredom leads to eating for entertainment, not hunger"}],["$","li","1",{"className":"text-gray-700","children":"Dry kibble is calorie-dense and easy to overeat"}],["$","li","2",{"className":"text-gray-700","children":"Cats lack natural satiety signals in captive environments"}],["$","li","3",{"className":"text-gray-700","children":"Commercial dry food is often high-sugar and addictive"}]]}],["$","p","5",{"className":"text-gray-700 leading-relaxed my-4","children":"Obesity in cats leads to:"}],["$","ul","6",{"className":"list-disc list-inside space-y-2 my-4","children":[["$","li","0",{"className":"text-gray-700","children":"Type 2 diabetes (reversible with weight loss)"}],["$","li","1",{"className":"text-gray-700","children":"Joint problems and arthritis"}],["$","li","2",{"className":"text-gray-700","children":"Kidney disease and urinary issues"}],["$","li","3",{"className":"text-gray-700","children":"Fatty liver disease"}],["$","li","4",{"className":"text-gray-700","children":"Shortened lifespan (overweight cats live 2-3 years less)"}],"$L3"]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e","$L4f","$L50","$L51","$L52","$L53"]}]}],"$L54","$L55","$L56","$L57","$L58"]}],["$L59"],"$L5a"]}],"loading":null,"isPartial":false}
