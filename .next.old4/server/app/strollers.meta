{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/strollers/layout,_N_T_/strollers/page,_N_T_/strollers"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/strollers/__PAGE__",
    "/strollers",
    "/_index",
    "/_head"
  ]
}