d:["$","article",null,{"className":"bg-white","children":[["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-6","children":["$","nav",null,{"className":"flex items-center space-x-2 text-sm text-gray-600","children":[["$","$L5",null,{"href":"/","className":"hover:text-blue-600","children":"Home"}],[["$","div","/pet-cameras",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","$L5",null,{"href":"/pet-cameras","className":"hover:text-blue-600","children":"Pet Cameras"}]]}],["$","div","/pet-cameras/multi-pet-monitoring-camera-setup",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","span",null,{"className":"text-gray-900 font-medium","children":"Multi-Pet Monitoring with Cameras: Setup Guide for Multiple Dogs and Cats"}]]}]]]}]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-b border-gray-200","children":[["$","h1",null,{"className":"text-4xl font-bold text-gray-900 mb-4","children":"Multi-Pet Monitoring with Cameras: Setup Guide for Multiple Dogs and Cats"}],["$","p",null,{"className":"text-lg text-gray-600","children":"Design a multi-camera pet monitoring system for households with multiple pets. Learn camera placement, app organization, alert management, and managing different pet behaviors across rooms."}]]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700","children":[["$","h2","0",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-gray-700 mb-4","children":"Monitoring multiple pets presents unique challenges: Which camera watches which pet? What happens when you have alerts from three cameras simultaneously? How do you organize video footage from multiple devices? How do you prevent alert fatigue from every pet movement? This guide covers everything you need to set up an effective multi-pet monitoring system, from camera placement to app management and alert strategies."}],["$","h2","2",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Why Multi-Pet Monitoring Is Complex"}],["$","h2","3",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Challenges of Monitoring Multiple Pets"}],["$","p","4",{"className":"text-gray-700 mb-4","children":"**Volume problem:** One pet camera generates 1-50 alerts per day (motion, sound, activity). Three cameras? That's 3-150 alerts. Managing alert overload is critical."}],["$","p","5",{"className":"text-gray-700 mb-4","children":"**Behavior differentiation:** Normal behavior (dog playing) versus concerning behavior (cat in distress) look similar on video. You need context for each pet."}],["$","p","6",{"className":"text-gray-700 mb-4","children":"**Technical complexity:** Pairing three cameras, managing three separate apps (or one app with poor multi-camera interface), organizing footage from multiple devices."}],["$","p","7",{"className":"text-gray-700 mb-4","children":"**Battery management:** If using portable cameras, you're charging 3+ devices instead of 1."}],["$","p","8",{"className":"text-gray-700 mb-4","children":"**WiFi bandwidth:** Multiple cameras streaming simultaneously stresses your home WiFi; poor connectivity affects video quality."}],["$","p","9",{"className":"text-gray-700 mb-4","children":"**Storage explosion:** Three cameras recording all day = gigabytes of storage daily. Cloud subscriptions add up quickly."}],["$","p","10",{"className":"text-gray-700 mb-4","children":"**Alert fatigue:** Constant notifications from multiple cameras cause you to ignore even important alerts (alert blindness)."}],"$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e","$L4f","$L50","$L51","$L52","$L53","$L54","$L55","$L56","$L57","$L58","$L59","$L5a","$L5b","$L5c","$L5d","$L5e","$L5f","$L60","$L61","$L62","$L63","$L64","$L65","$L66","$L67","$L68","$L69","$L6a","$L6b","$L6c","$L6d","$L6e","$L6f","$L70","$L71","$L72"]}]}],"$L73","$L74","$L75"]}]
7c:I[31175,["/_next/static/chunks/7bb08ad39a4b23f0.js","/_next/static/chunks/5935fefdd9fc8f83.js"],"default"]
15:["$","h2","11",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Multi-Pet Monitoring System Architecture"}]
16:["$","h2","12",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#System Components"}]
17:["$","p","13",{"className":"text-gray-700 mb-4","children":"A complete multi-pet monitoring system includes:"}]
18:["$","ol","14",{"className":"list-decimal list-inside mb-4 space-y-2","children":[["$","li","0",{"className":"text-gray-700","children":"**Cameras** (one per pet or shared area)"}],["$","li","1",{"className":"text-gray-700","children":"**WiFi network** (robust router; adequate bandwidth)"}],["$","li","2",{"className":"text-gray-700","children":"**Cloud or local storage** (backup for footage)"}],["$","li","3",{"className":"text-gray-700","children":"**Mobile app** (unified management and alerts)"}],["$","li","4",{"className":"text-gray-700","children":"**Alert rules** (smart filtering to prevent overwhelm)"}],["$","li","5",{"className":"text-gray-700","children":"**Power management** (charging docks or plug-in considerations)"}]]}]
19:["$","h2","15",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Bandwidth Requirements"}]
1a:["$","p","16",{"className":"text-gray-700 mb-4","children":"**Per-camera streaming:**\n- 1080p video: 1-4 Mbps\n- 2K video: 2-6 Mbps\n- Audio (two-way): 0.1-0.5 Mbps"}]
1b:["$","p","17",{"className":"text-gray-700 mb-4","children":"**Example:** Two 1080p cameras + one 2K camera = ~6-14 Mbps continuous\nYour home WiFi should have 30+ Mbps download speed to comfortably handle multiple cameras plus other devices (computers, phones, gaming)."}]
1c:["$","p","18",{"className":"text-gray-700 mb-4","children":"**Test your setup:**\nUse a speed test app (Ookla Speedtest) while cameras stream. If speeds drop below 10 Mbps, you'll experience buffering, lag, or dropped connections."}]
1d:["$","p","19",{"className":"text-gray-700 mb-4","children":"**Solutions for limited bandwidth:**\n- Use wired Ethernet cameras (avoid WiFi)\n- Reduce video resolution (1080p instead of 2K)\n- Enable motion-triggered recording (not continuous)\n- Position cameras closer to router (reduce interference)"}]
1e:["$","h2","20",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Camera Placement for Multiple Pets"}]
1f:["$","h2","21",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Placement Strategy by Pet Type"}]
20:["$","p","22",{"className":"text-gray-700 mb-4","children":"**High-activity areas (dogs playing):**\n- Main living room: Wide-angle camera captures play area\n- Kitchen: Captures feeding area and food-stealing attempts\n- Basement/playroom: Full room overview"}]
21:["$","p","23",{"className":"text-gray-700 mb-4","children":"**Quiet rest areas (cats sleeping):**\n- Bedroom: Elevated position overlooking cat bed\n- Cat room: Centered to see all furniture levels\n- Window perch: Captures outdoor bird-watching behavior"}]
22:["$","p","24",{"className":"text-gray-700 mb-4","children":"**Exits and transitions:**\n- Doors between rooms: Captures pet movement between spaces\n- Stairways: Monitors safe descent/ascent\n- Pet enclosures: Ensures escape prevention"}]
23:["$","h2","25",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Positioning Best Practices"}]
24:["$","p","26",{"className":"text-gray-700 mb-4","children":"**Height and angle:**\n- Mount at 4-6 feet height (eye level of adult human looking down at pets)\n- Angle slightly down 15-20 degrees (captures pet behavior clearly)\n- Avoid pointing directly at windows (backlighting ruins image)"}]
25:["$","p","27",{"className":"text-gray-700 mb-4","children":"**Coverage overlap:**\n- Adjacent rooms: 10-20% overlap area (ensures no blind spots)\n- Don't over-lap unnecessarily (wastes storage, creates redundancy)"}]
26:["$","p","28",{"className":"text-gray-700 mb-4","children":"**Field of view:**\n- 130-160 degrees for general monitoring\n- Wider angles (150-180°) for large rooms\n- Narrower angles (100-120°) for focused areas (cat bed, crate)"}]
27:["$","h2","29",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Example 3-Pet Setup"}]
28:["$","p","30",{"className":"text-gray-700 mb-4","children":"**Household:** 2 dogs (large + small) + 1 cat"}]
29:["$","p","31",{"className":"text-gray-700 mb-4","children":"**Camera placement:**\n1. **Living room** — Pan/tilt 1080p camera, wide-angle\n   - Covers both dogs' play area\n   - Height: 5 feet (upper shelf)\n   - Why: Main activity area; one camera can cover multiple pets"}]
2a:["$","ol","32",{"className":"list-decimal list-inside mb-4 space-y-2","children":[["$","li","0",{"className":"text-gray-700","children":"**Bedroom** — Fixed 1080p camera, narrow angle"}],["$","li","1",{"className":"text-gray-700","children":"   - Covers cat bed/furniture; bedroom pet rest area"}],["$","li","2",{"className":"text-gray-700","children":"   - Height: 6 feet (top of dresser)"}],["$","li","3",{"className":"text-gray-700","children":"   - Why: Monitors cat's nighttime behavior separately from dogs"}]]}]
2b:["$","ol","33",{"className":"list-decimal list-inside mb-4 space-y-2","children":[["$","li","0",{"className":"text-gray-700","children":"**Kitchen** — Fixed 1080p camera, moderate wide-angle"}],["$","li","1",{"className":"text-gray-700","children":"   - Covers feeding station and dining area"}],["$","li","2",{"className":"text-gray-700","children":"   - Height: 4 feet (mounted on wall near feeder)"}],["$","li","3",{"className":"text-gray-700","children":"   - Why: Captures food guarding, feeding conflicts, food theft"}]]}]
2c:["$","p","34",{"className":"text-gray-700 mb-4","children":"**Total cost:** $150-300 (assuming $50-100 per camera)"}]
2d:["$","p","35",{"className":"text-gray-700 mb-4","children":"**Coverage:** Living room + bedroom + kitchen = 80% of pet activity spaces"}]
2e:["$","p","36",{"className":"text-gray-700 mb-4","children":"**Gaps:** Hallways, bathrooms (less critical for pet monitoring)"}]
2f:["$","h2","37",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Multi-Camera App Management"}]
30:["$","h2","38",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Unified App Approach (Best Option)"}]
31:["$","p","39",{"className":"text-gray-700 mb-4","children":"Use cameras that work with a single app ecosystem. Examples:"}]
32:["$","p","40",{"className":"text-gray-700 mb-4","children":"**Best multi-camera apps:**"}]
33:["$","p","41",{"className":"text-gray-700 mb-4","children":"**1. Wyze App**\n- Supports unlimited cameras in one app\n- Excellent multi-camera interface (grid view)\n- Free cloud storage (limited) + paid storage ($1.99/mo)\n- Device support: Wyze Cam v3 ($49), Wyze Cam Pan v3 ($59), budget-friendly\n- Best for: Budget-conscious multi-pet households"}]
34:["$","p","42",{"className":"text-gray-700 mb-4","children":"**2. Eufy App (Anker)**\n- Supports multiple cameras in one interface\n- Better video quality than Wyze (1440p standard)\n- Free local storage (no cloud required!)\n- Cameras: Eufy IndoorCam 2K ($99), Pan/Tilt ($119)\n- Best for: Privacy-conscious owners; no subscription requirement"}]
35:["$","p","43",{"className":"text-gray-700 mb-4","children":"**3. PETKIT App**\n- Purpose-built for pet cameras\n- Pet-specific interface (alerts for pet activity, not just motion)\n- Multiple camera support\n- Cameras: PETKIT Enabot ($99), Enabot Pan ($129)\n- Best for: Pet-specific features like pet recognition"}]
36:["$","p","44",{"className":"text-gray-700 mb-4","children":"**4. Furbo App**\n- Popular for pet-specific features (treat dispensing)\n- Multi-camera interface available (premium)\n- Focus on interactive features (talk, treat toss)\n- Cameras: Furbo ($249), Furbo 360 ($299)\n- Best for: Interaction and training focus"}]
37:["$","h2","45",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Fragmented App Approach (Avoid)"}]
38:["$","p","46",{"className":"text-gray-700 mb-4","children":"Some pet cameras don't integrate into unified apps:\n- You have separate apps for each camera brand\n- Switching between three apps to check on pets is tedious\n- Alerts come from separate notifications (notification overload)\n- Video organization is fragmented (different file systems)"}]
39:["$","p","47",{"className":"text-gray-700 mb-4","children":"**Avoid this situation** if possible. Choose cameras with unified app support."}]
3a:["$","h2","48",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Alert Management: Preventing Alert Fatigue"}]
3b:["$","h2","49",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Understanding Alert Fatigue"}]
3c:["$","p","50",{"className":"text-gray-700 mb-4","children":"Alert fatigue occurs when constant notifications cause you to ignore even important alerts. Pet owners report checking phones hundreds of times per day, eventually tuning out notifications entirely."}]
3d:["$","p","51",{"className":"text-gray-700 mb-4","children":"\"I had so many false alerts from dust and shadows that I stopped checking. Then my dog actually escaped, and I missed the alert.\""}]
3e:["$","h2","52",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Smart Alert Rules"}]
3f:["$","p","53",{"className":"text-gray-700 mb-4","children":"Configure alerts to reduce noise without missing important events:"}]
40:["$","p","54",{"className":"text-gray-700 mb-4","children":"**Rule 1: Motion-Based Alerts Only During Specific Hours**"}]
41:["$","p","55",{"className":"text-gray-700 mb-4","children":"Example setup:\n- **7:00am - 9:00pm:** Motion alerts enabled (active pet times)\n- **9:00pm - 7:00am:** Only sound/unusual activity alerts enabled (sleeping pets don't need motion alerts)\n- **Result:** Eliminates thousands of false motion alerts from sleeping pets"}]
42:["$","p","56",{"className":"text-gray-700 mb-4","children":"**Rule 2: Sound-Based Alerts for Unusual Behavior**"}]
43:["$","p","57",{"className":"text-gray-700 mb-4","children":"Enable alerts only for:\n- Excessive barking (dogs in distress)\n- Crying or meowing (cats in pain/stress)\n- Unusual sounds (breaking glass, aggressive barking)"}]
44:["$","p","58",{"className":"text-gray-700 mb-4","children":"Disable alerts for:\n- Normal barking (ignore >2 barks)\n- Regular sounds (lapping water, eating kibble)"}]
45:["$","p","59",{"className":"text-gray-700 mb-4","children":"**Rule 3: Pet-Specific Zones**"}]
46:["$","p","60",{"className":"text-gray-700 mb-4","children":"Define zones for each pet's normal behavior:\n- **Dog zone (living room):** Motion alerts normal\n- **Cat zone (bedroom):** Only sound alerts (cats are quiet; motion is normal)\n- **Kitchen zone (feeding):** Motion alerts 7am-9am only (feeding time)"}]
47:["$","p","61",{"className":"text-gray-700 mb-4","children":"**Rule 4: Alert Cooldown Periods**"}]
48:["$","p","62",{"className":"text-gray-700 mb-4","children":"Most apps allow alert cooldown (e.g., \"no alert within 5 minutes of last alert from same camera\"):\n- Prevents duplicate alerts for same event\n- Reduces notification volume by 50-70%\n- Recommended: 5-10 minute cooldown"}]
49:["$","p","63",{"className":"text-gray-700 mb-4","children":"**Example alert configuration for 3 cameras:**\n- Living room: Motion + sound alerts, 7am-11pm, 10-minute cooldown\n- Bedroom: Sound-only alerts (crying/distress), all hours, 15-minute cooldown\n- Kitchen: Motion alerts, 7am-9am + 5pm-7pm (feeding times), 5-minute cooldown"}]
4a:["$","p","64",{"className":"text-gray-700 mb-4","children":"**Result:** ~3-10 alerts per day (manageable) vs. 50-150 (unsustainable)"}]
4b:["$","h2","65",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Custom Alert Examples"}]
4c:["$","div","66",{"className":"overflow-x-auto mb-4","children":["$","table",null,{"className":"w-full text-sm border-collapse","children":[["$","thead",null,{"className":"bg-gray-100","children":["$","tr",null,{"children":[["$","th","0",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Pet Behavior"}],["$","th","1",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Alert Setting"}],["$","th","2",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Purpose"}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"className":"bg-white","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"Dog barking in living room"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"Sound alert if >5 barks in 30 sec"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"Alerts to excessive barking only"}]]}],["$","tr","1",{"className":"bg-gray-50","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"Cat in bedroom at night"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"No motion alerts (cats move normally at night)"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"Eliminates false alerts while sleeping"}]]}],["$","tr","2",{"className":"bg-white","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"Dog at feeding station"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"Motion alert 7-9am + 5-7pm"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"Captures feeding time activities"}]]}],["$","tr","3",{"className":"bg-gray-50","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"Unusual activity"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"Motion + sound alerts all hours"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"Captures potential emergency situations"}]]}]]}]]}]}]
4d:["$","h2","67",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Video Organization and Storage"}]
4e:["$","h2","68",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Storage Strategy for Multiple Cameras"}]
4f:["$","p","69",{"className":"text-gray-700 mb-4","children":"**Local storage (no cloud):**\n- Each camera stores footage on microSD card\n- Cost: $10-30 per camera (microSD cards)\n- Retention: 7-30 days depending on card size\n- Advantage: Privacy, no monthly fees\n- Disadvantage: Manual management; footage lost if camera stolen"}]
50:["$","p","70",{"className":"text-gray-700 mb-4","children":"**Cloud storage (paid subscriptions):**\n- Example: Wyze cloud storage at $1.99/mo per camera\n- 3 cameras = $6/mo ($72/year)\n- Retention: 14-30 days\n- Advantage: Automatic backup; accessible from anywhere; searchable\n- Disadvantage: Monthly cost adds up; privacy concerns; data vulnerability"}]
51:["$","p","71",{"className":"text-gray-700 mb-4","children":"**Hybrid approach (best):**\n- Local microSD storage as primary (cheap, private)\n- Cloud backup for critical incidents (subscription for video evidence if needed)\n- Cost: $30-50 (cards) + $5-10/month (optional cloud) = ~$100/year"}]
52:["$","h2","72",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Organization Tips"}]
53:["$","p","73",{"className":"text-gray-700 mb-4","children":"**Naming convention:** Name cameras by location\n- \"Living Room - Dog\"\n- \"Bedroom - Cat\"\n- \"Kitchen - Feeding Station\""}]
54:["$","p","74",{"className":"text-gray-700 mb-4","children":"**Search tools:** Use app search features\n- Search by date/time\n- Search by pet name (if app supports tagging)\n- Search by alert type (motion, sound)"}]
55:["$","p","75",{"className":"text-gray-700 mb-4","children":"**Backup critical footage:** Download important videos to computer\n- Escape attempts\n- Behavioral incidents\n- Medical events (seizures, injuries)\n- Training milestones"}]
56:["$","p","76",{"className":"text-gray-700 mb-4","children":"**Archive old footage:** Delete footage older than 30 days\n- Saves storage space\n- Keeps library manageable\n- Prevents storage overflow"}]
57:["$","h2","77",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Power Management for Multiple Cameras"}]
58:["$","h2","78",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Plug-in Cameras vs Battery-Powered"}]
59:["$","p","79",{"className":"text-gray-700 mb-4","children":"**Plug-in cameras:**\n- Advantages: Always on, no charging needed, better performance\n- Disadvantages: Limited placement (need nearby outlets)\n- Cost per camera: $50-300 (once)"}]
5a:["$","p","80",{"className":"text-gray-700 mb-4","children":"**Battery-powered cameras:**\n- Advantages: Flexible placement, no outlets needed\n- Disadvantages: Frequent charging, battery degrades over time\n- Cost: $100-200 per camera + charging dock ($30-50)"}]
5b:["$","h2","81",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Recommended Multi-Pet Setup"}]
5c:["$","p","82",{"className":"text-gray-700 mb-4","children":"**For 3-camera household:**\n- 1-2 plug-in cameras (living room, kitchen): Always on\n- 1 battery camera (bedroom): Flexible placement, charge weekly\n- Charging dock: $30-50 (charges while you sleep)"}]
5d:["$","p","83",{"className":"text-gray-700 mb-4","children":"**Charging schedule for battery cameras:**\n- Charge every 3-5 days\n- Weekly full charge recommended\n- Keep spare battery (2-3 cameras require 2+ batteries)\n- Use quick-charge USB-C models (15-30 minute full charge)"}]
5e:["$","h2","84",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Troubleshooting Multi-Camera Issues"}]
5f:["$","h2","85",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Problem: Frequent Disconnections"}]
60:["$","p","86",{"className":"text-gray-700 mb-4","children":"**Causes:**\n- WiFi too far from router\n- WiFi channel congestion\n- Weak router signal"}]
61:["$","p","87",{"className":"text-gray-700 mb-4","children":"**Solutions:**\n1. Move router closer to cameras (central location)\n2. Switch WiFi to less congested channel (use WiFi analyzer app)\n3. Upgrade to WiFi 6 router ($100-200)\n4. Use wired Ethernet cameras (no WiFi needed)\n5. Add WiFi extender ($50-100)"}]
62:["$","h2","88",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Problem: Video Lag or Buffering"}]
63:["$","p","89",{"className":"text-gray-700 mb-4","children":"**Causes:**\n- Insufficient bandwidth\n- Too many devices on network\n- Low WiFi signal"}]
64:["$","p","90",{"className":"text-gray-700 mb-4","children":"**Solutions:**\n1. Reduce camera resolution (1080p instead of 2K)\n2. Enable motion-triggered recording (not continuous)\n3. Limit number of simultaneous streams\n4. Check internet speed (should be 30+ Mbps download)\n5. Connect camera to 5GHz WiFi band (faster than 2.4GHz)"}]
65:["$","h2","91",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Problem: Alert Overload"}]
66:["$","p","92",{"className":"text-gray-700 mb-4","children":"**Causes:**\n- Alert settings too sensitive\n- Dust, shadows, reflections triggering motion\n- No cooldown periods configured"}]
67:["$","p","93",{"className":"text-gray-700 mb-4","children":"**Solutions:**\n1. Implement alert rules (section above)\n2. Enable motion zones (ignore hallways, focus on pet areas)\n3. Add 5-10 minute alert cooldown\n4. Disable motion alerts during sleeping hours\n5. Use sound-based alerts (more specific than motion)"}]
68:["$","h2","94",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Problem: Lost Footage"}]
69:["$","p","95",{"className":"text-gray-700 mb-4","children":"**Causes:**\n- Storage full\n- Camera power loss\n- Cloud account issues"}]
6a:["$","p","96",{"className":"text-gray-700 mb-4","children":"**Solutions:**\n1. Check storage regularly\n2. Delete old footage manually\n3. Enable automatic cloud backup (if available)\n4. Download critical footage before storage fills\n5. Use multiple storage methods (local + cloud)"}]
6b:["$","h2","97",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Cost Breakdown: Multi-Pet Camera System"}]
6c:["$","h2","98",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Budget Setup (3 Cameras)\n- 3× Wyze Cam v3: $49 × 3 = $147\n- MicroSD cards: $15 × 3 = $45\n- Charging dock (2 USB ports): $20\n- **Total: $212**\n- Monthly cost: $0 (free cloud tier) or $6 (paid cloud)"}]
6d:["$","h2","99",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Mid-Range Setup (3 Cameras)\n- 2× Eufy IndoorCam 2K: $99 × 2 = $198\n- 1× Eufy Pan/Tilt: $119\n- Storage: Local only, no subscription needed\n- **Total: $317**\n- Monthly cost: $0 (no subscriptions)"}]
6e:["$","h2","100",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"#Premium Setup (3 Cameras)\n- 3× Furbo 360: $299 × 3 = $897\n- Cloud storage: $10/mo ($120/year)\n- Treat refill subscription: $15/mo ($180/year)\n- **Total: $897 upfront + $300/year**\n- Monthly cost: $25"}]
6f:["$","h2","101",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Conclusion"}]
70:["$","p","102",{"className":"text-gray-700 mb-4","children":"Multi-pet monitoring requires thoughtful camera placement, unified app management, and smart alert rules to avoid overwhelming yourself with notifications. The ideal setup includes:"}]
71:["$","ol","103",{"className":"list-decimal list-inside mb-4 space-y-2","children":[["$","li","0",{"className":"text-gray-700","children":"**One camera per major pet area** (living room for dogs, bedroom for cat)"}],["$","li","1",{"className":"text-gray-700","children":"**Unified app management** (one app for all cameras, not separate apps)"}],["$","li","2",{"className":"text-gray-700","children":"**Smart alert rules** (time-based, zone-based, sound-triggered to reduce false alarms)"}],["$","li","3",{"className":"text-gray-700","children":"**Local + cloud storage** (microSD for privacy, cloud for backup)"}],["$","li","4",{"className":"text-gray-700","children":"**Balanced power management** (mix of plug-in + battery cameras)"}]]}]
72:["$","p","104",{"className":"text-gray-700 mb-4","children":"Start with 2-3 cameras covering main activity areas, configure smart alerts to eliminate noise, and expand to additional cameras only if you identify gaps. The goal is monitoring peace of mind, not alert fatigue. A well-configured 2-camera system beats a poorly configured 5-camera system every time."}]
