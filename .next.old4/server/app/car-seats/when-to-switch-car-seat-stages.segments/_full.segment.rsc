d:["$","article",null,{"className":"bg-white","children":[["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-6","children":["$","nav",null,{"className":"flex items-center space-x-2 text-sm text-gray-600","children":[["$","$L5",null,{"href":"/","className":"hover:text-blue-600","children":"Home"}],[["$","div","/car-seats",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","$L5",null,{"href":"/car-seats","className":"hover:text-blue-600","children":"Car Seats"}]]}],["$","div","/car-seats/when-to-switch-car-seat-stages",{"className":"flex items-center space-x-2","children":[["$","span",null,{"className":"text-gray-400","children":"/"}],["$","span",null,{"className":"text-gray-900 font-medium","children":"When to Switch Car Seats: Transition Timeline and Safety Guidelines"}]]}]]]}]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-b border-gray-200","children":[["$","h1",null,{"className":"text-4xl font-bold text-gray-900 mb-4","children":"When to Switch Car Seats: Transition Timeline and Safety Guidelines"}],["$","p",null,{"className":"text-lg text-gray-600","children":"Learn the car seat transition timeline: when to move from infant to convertible, rear-facing to forward-facing, and convertible to booster seats. Includes weight, height, and age guidelines."}]]}],["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700","children":[["$","h2","0",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-gray-700 leading-relaxed my-4","children":"Car seat transitions are among the most misunderstood aspects of child vehicle safety. Many parents transition children too early because they believe age or reaching a certain weight is sufficient. In reality, car seats have minimum and maximum thresholds for each mode, and understanding the difference between \"minimum\" (when transition becomes possible) and \"recommended\" (when transition is safest) is critical to protecting your child."}],["$","p","2",{"className":"text-gray-700 leading-relaxed my-4","children":"This guide walks through every transition, explains the safety reasoning behind each age/weight threshold, and answers the most common questions parents ask about timing."}],["$","h2","3",{"className":"text-2xl font-bold text-gray-900 mt-8 mb-4","children":"The Car Seat Timeline: Overview"}],["$","p","4",{"className":"text-gray-700 leading-relaxed my-4","children":"Here's the complete progression a child typically follows:"}],["$","div","5",{"className":"overflow-x-auto my-6","children":["$","table",null,{"className":"w-full border-collapse text-sm","children":[["$","thead",null,{"className":"bg-gray-100","children":["$","tr",null,{"children":[["$","th","0",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Stage"}],["$","th","1",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Seat Type"}],["$","th","2",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Typical Age"}],["$","th","3",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Typical Weight"}],["$","th","4",{"className":"border border-gray-300 px-4 py-2 text-left font-bold","children":"Typical Duration"}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"className":"bg-white","children":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"Infant"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"Infant car seat or convertible (rear-facing)"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"0-12 months"}],["$","td","3",{"className":"border border-gray-300 px-4 py-2","children":"5-35 lbs"}],"$L15"]}],"$L16","$L17","$L18","$L19","$L1a"]}]]}]}],"$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e","$L4f","$L50","$L51","$L52","$L53","$L54","$L55","$L56","$L57","$L58","$L59","$L5a","$L5b","$L5c","$L5d","$L5e","$L5f","$L60","$L61","$L62","$L63","$L64","$L65","$L66","$L67","$L68","$L69","$L6a","$L6b","$L6c","$L6d","$L6e","$L6f","$L70","$L71","$L72","$L73","$L74","$L75","$L76","$L77","$L78","$L79","$L7a","$L7b","$L7c","$L7d","$L7e","$L7f","$L80","$L81","$L82","$L83","$L84","$L85","$L86","$L87","$L88","$L89","$L8a","$L8b","$L8c","$L8d","$L8e","$L8f","$L90","$L91","$L92","$L93"]}]}],"$L94","$L95"]}]
