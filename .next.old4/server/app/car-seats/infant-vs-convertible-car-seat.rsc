ildren":[["$","td","0",{"className":"border border-gray-300 px-4 py-2","children":"**Resale value**"}],["$","td","1",{"className":"border border-gray-300 px-4 py-2","children":"High demand"}],["$","td","2",{"className":"border border-gray-300 px-4 py-2","children":"Moderate demand"}]]}],"$L4a","$L4b","$L4c"]}]]}]}]
